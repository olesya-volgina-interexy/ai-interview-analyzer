generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Interview {
  id            String   @id @default(uuid())
  transcript    String
  cvText        String?
  brokerRequest String?
  stage         String
  role          String
  level         String
  decision      String?
  clientName    String?
  candidateName String?
  comments      String?
  krisLink      String?
  cvUrl         String?
  linearIssueId String?
  parentCommentId String?
  analysis      Json
  embeddingId   String?
  managerName   String?
  questions     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([linearIssueId, parentCommentId, stage])
}

model Client {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  insights    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IncomingRequest {
  id            String   @id @default(uuid())
  linearIssueId String?  @unique
  clientName    String?
  role          String?
  level         String?
  brokerRequest String?  @db.Text
  status           String   // 'triage' | 'new' | 'in_progress' | 'client_review' | 'cv_sent' | 'manager_call' | 'technical' | 'hired' | 'rejected' | 'on_hold' | 'dropped'
  cvSentCount      Int      @default(0)
  externalFeedback String?  @db.Text
  receivedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  statusHistory    IncomingRequestStatusHistory[]

  @@index([receivedAt, status])
}

model IncomingRequestStatusHistory {
  id                String          @id @default(uuid())
  incomingRequestId String
  request           IncomingRequest @relation(fields: [incomingRequestId], references: [id], onDelete: Cascade)
  status            String
  enteredAt         DateTime        @default(now())

  @@index([incomingRequestId, enteredAt])
}