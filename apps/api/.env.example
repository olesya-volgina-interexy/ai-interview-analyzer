# Database
DATABASE_URL=postgresql://user:password@host:5432/interviews

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=https://your-cluster-id.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
# Qdrant collection name (optional, defaults to 'interviews')
QDRANT_COLLECTION=interviews

# LLM
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://your-llm-provider.com/v1
LLM_MODEL=your-model-name
# Embedding model (optional, defaults to 'text-embedding-v4')
EMBEDDING_MODEL=text-embedding-v3

# Linear
LINEAR_API_KEY=your_linear_api_key
LINEAR_WEBHOOK_SECRET=your_webhook_secret

# Krisp (required if using Krisp integration)
KRISP_WEBHOOK_SECRET=your_krisp_webhook_secret

# Chrome path for Puppeteer/Bluedot (set automatically in Docker via Dockerfile ENV)
# CHROME_PATH=/usr/bin/chromium

# CORS (comma-separated list of allowed frontend URLs)
CORS_ORIGIN=http://localhost:5173

# Server
PORT=3001
NODE_ENV=production
