# ── LLM ──────────────────────────────────────
LLM_API_KEY=твой_ключ_от_qwen
LLM_BASE_URL=https://api.qwen.ai/v1  
LLM_MODEL=qwen-plus

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/interviews

# ── Qdrant (векторная БД) ────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interviews

# ── Redis (очередь BullMQ) ───────────────────
REDIS_URL=redis://localhost:6379

# ── Linear ───────────────────────────────────
LINEAR_API_KEY=lin_api_...
LINEAR_WEBHOOK_SECRET=your_webhook_secret

# ── Krisp / Bluedot ──────────────────────────
KRISP_WEBHOOK_SECRET=your_krisp_secret

# ── App ──────────────────────────────────────
PORT=3001
NODE_ENV=development